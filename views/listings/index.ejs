<% layout("/layouts/boilerplate") %>

<div class="container-fluid px-4">

  <!-- Filter Bar -->
  <div class="wl-filter-bar">
    <a href="/listings" class="wl-filter <%= !category ? 'active' : '' %>">
      <i class="fa-solid fa-border-all"></i>
      <span>All</span>
    </a>
    <a href="/listings?category=trending" class="wl-filter <%= category === 'trending' ? 'active' : '' %>">
      <i class="fa-solid fa-fire"></i>
      <span>Trending</span>
    </a>
    <a href="/listings?category=rooms" class="wl-filter <%= category === 'rooms' ? 'active' : '' %>">
      <i class="fa-solid fa-bed"></i>
      <span>Rooms</span>
    </a>
    <a href="/listings?category=iconic_cities" class="wl-filter <%= category === 'iconic_cities' ? 'active' : '' %>">
      <i class="fa-solid fa-mountain-city"></i>
      <span>Iconic Cities</span>
    </a>
    <a href="/listings?category=castles" class="wl-filter <%= category === 'castles' ? 'active' : '' %>">
      <i class="fa-brands fa-fort-awesome"></i>
      <span>Castles</span>
    </a>
    <a href="/listings?category=mountain" class="wl-filter <%= category === 'mountain' ? 'active' : '' %>">
      <i class="fa-solid fa-mountain-sun"></i>
      <span>Mountain</span>
    </a>
    <a href="/listings?category=camping" class="wl-filter <%= category === 'camping' ? 'active' : '' %>">
      <i class="fa-solid fa-tent"></i>
      <span>Camping</span>
    </a>
    <a href="/listings?category=beach" class="wl-filter <%= category === 'beach' ? 'active' : '' %>">
      <i class="fa-solid fa-umbrella-beach"></i>
      <span>Beach</span>
    </a>
    <a href="/listings?category=nature" class="wl-filter <%= category === 'nature' ? 'active' : '' %>">
      <i class="fa-solid fa-person-swimming"></i>
      <span>Nature</span>
    </a>

    <!-- Tax Toggle -->
    <label class="wl-tax-toggle">
      <label class="wl-switch">
        <input type="checkbox" id="taxToggle"/>
        <span class="wl-slider"></span>
      </label>
      <span>Show taxes</span>
    </label>
  </div>

  <!-- Search result heading -->
  <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
    <div style="padding:16px 0 4px; font-size:14px; color:var(--ink-soft);">
      Showing results for <strong style="color:var(--ink);">"<%= searchQuery %>"</strong>
      &nbsp;·&nbsp; <a href="/listings" style="color:var(--gold);text-decoration:none;">Clear</a>
    </div>
  <% } %>

  <!-- Listings Grid -->
  <div class="wl-listings-grid">
    <% if(allListings.length === 0) { %>
      <div class="wl-empty">
        <h3>No listings found</h3>
        <p>Try a different search or category.</p>
        <a href="/listings" class="wl-btn wl-btn-primary" style="margin-top:20px;">View all listings</a>
      </div>
    <% } %>

    <% for(let listing of allListings) { %>
      <a href="/listings/<%= listing._id %>" class="wl-listing-link">
        <div class="wl-card">
          <div class="wl-card-img-wrap">
            <img src="<%= listing.image.url %>" class="wl-card-img" alt="<%= listing.title %>"/>
            <div class="wl-card-badge">Wanderlust</div>
            <button class="wl-card-wishlist" onclick="event.preventDefault();" title="Save">
              <i class="fa-regular fa-heart"></i>
            </button>
          </div>
          <div class="wl-card-body">
            <% if(listing.category) { %>
              <div class="wl-card-category"><%= listing.category.replace('_', ' ') %></div>
            <% } %>
            <div class="wl-card-title"><%= listing.title %></div>
            <div class="wl-card-location">
              <i class="fa-solid fa-location-dot"></i>
              <%= listing.location %>, <%= listing.country %>
            </div>
            <div class="wl-card-footer">
              <div class="wl-card-price">
                <strong>&#8377;<%= listing.price.toLocaleString('en-IN') %></strong>
                <span style="font-size:13px;color:var(--ink-soft);font-weight:400;"> /night</span>
                <span class="tax-info">+18% GST</span>
              </div>
              <% if(listing.reviews && listing.reviews.length > 0) { %>
                <div class="wl-card-rating">
                  <i class="fa-solid fa-star"></i>
                  <%
                    // Calculate average rating if reviews are populated
                    let avgRating = listing.reviews.length > 0
                      ? (listing.reviews.reduce((sum, r) => sum + (r.rating || 0), 0) / listing.reviews.length).toFixed(1)
                      : null;
                  %>
                  <%= avgRating || '–' %>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </a>
    <% } %>
  </div>
</div>

<script>
  // Tax toggle
  document.getElementById('taxToggle').addEventListener('change', function() {
    document.querySelectorAll('.tax-info').forEach(el => {
      el.style.display = this.checked ? 'inline' : 'none';
    });
  });
</script>
