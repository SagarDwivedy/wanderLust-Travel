<% layout("/layouts/boilerplate") %>

<div class="wl-form-page">
  <div class="wl-form-card">
    <h2 class="wl-form-title">Add a new listing</h2>
    <p class="wl-form-subtitle">Share your space with travellers around the world</p>

    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

      <div class="wl-form-group">
        <label class="wl-form-label" for="title">Title</label>
        <input name="listing[title]" id="title" type="text" class="wl-form-control"
          placeholder="e.g. Cozy Beachfront Cottage" required/>
      </div>

      <div class="wl-form-group">
        <label class="wl-form-label" for="description">Description</label>
        <textarea name="listing[description]" id="description" class="wl-form-control" rows="4"
          placeholder="Describe what makes your place special..." required></textarea>
      </div>

      <div class="wl-form-group">
        <label class="wl-form-label">Photo</label>
        <label class="wl-file-label" for="listingImage">
          <i class="fa-solid fa-cloud-arrow-up"></i>
          <span>Click to upload a photo</span>
          <small>JPG, PNG or WEBP · Max 5MB</small>
        </label>
        <input type="file" name="listing[image]" id="listingImage" class="wl-file-input" accept="image/*"/>
        <div id="fileNameDisplay" style="font-size:12px;color:var(--sage);margin-top:6px;"></div>
      </div>

      <div class="wl-form-row">
        <div class="wl-form-group">
          <label class="wl-form-label" for="price">Price per night (₹)</label>
          <div class="wl-input-prefix">
            <span class="prefix">₹</span>
            <input name="listing[price]" id="price" type="number" class="wl-form-control"
              placeholder="0" min="1" required/>
          </div>
        </div>
        <div class="wl-form-group">
          <label class="wl-form-label" for="category">Category</label>
          <select name="listing[category]" id="category" class="wl-select">
            <option value="">— Select category —</option>
            <option value="trending">Trending</option>
            <option value="rooms">Rooms</option>
            <option value="iconic_cities">Iconic Cities</option>
            <option value="castles">Castles</option>
            <option value="mountain">Mountain Views</option>
            <option value="camping">Camping</option>
            <option value="beach">Beach</option>
            <option value="nature">Amazing Nature</option>
          </select>
        </div>
      </div>

      <div class="wl-form-row">
        <div class="wl-form-group">
          <label class="wl-form-label" for="location">City / Location</label>
          <input name="listing[location]" id="location" type="text" class="wl-form-control"
            placeholder="e.g. Goa" required/>
        </div>
        <div class="wl-form-group">
          <label class="wl-form-label" for="country">Country</label>
          <input name="listing[country]" id="country" type="text" class="wl-form-control"
            placeholder="e.g. India" required/>
        </div>
      </div>

      <button type="submit" class="wl-btn wl-btn-primary wl-btn-lg" style="width:100%;margin-top:8px;justify-content:center;">
        <i class="fa-solid fa-plus"></i> Create Listing
      </button>
    </form>
  </div>
</div>

<script>
  document.getElementById('listingImage').addEventListener('change', function() {
    const name = this.files[0] ? this.files[0].name : '';
    document.getElementById('fileNameDisplay').textContent = name ? '📎 ' + name : '';
  });
</script>
